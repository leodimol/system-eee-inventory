import React, { useState, useEffect, useRef } from 'react';







import { X, Camera, Plus } from 'lucide-react';







import PhotoCapture from './PhotoCapture';







import { useUser } from '../context/UserContext';







import { supabase } from '../lib/supabase';







import { logAudit } from '../utils/auditLog';







import { getFullLocation } from '../utils/gpsLocation';







import {







  fetchAssetCategories,







  getMainCategories,







  getSubCategories,







  getAssetTypes,







  getCategoryId,







  getDynamicFields,







  getCategoryPath,







  fetchLocations







} from '../utils/assetCategoryLogistics';







import {







  validateAssetByType,







  validateAssetTag,







  validateLocationSelection







} from '../utils/assetValidationLogistics';















const AddAssetModal = ({ isOpen, onClose, asset = null, onSaved }) => {







  const { currentUser } = useUser();







  const isEditMode = Boolean(asset?.id);







  const [categories, setCategories] = useState([]);







  const [locations, setLocations] = useState([]);







  const [subCategories, setSubCategories] = useState([]);







  const [assetTypes, setAssetTypes] = useState([]);







  const [dynamicFields, setDynamicFields] = useState([]);







  const [photos, setPhotos] = useState({ userPhoto: null, assetPhoto: null });







  const [showPhotoCapture, setShowPhotoCapture] = useState(null);







  const [loading, setLoading] = useState(false);







  const [errors, setErrors] = useState({});







  const [showCategoryIntro, setShowCategoryIntro] = useState(!isEditMode);







  const initialFormRef = useRef(null);























  const statusOptions = [







    { value: 'Active', label: 'Active', badge: 'active' },







    { value: 'In Use', label: 'In Use', badge: 'in-use' },







    { value: 'Idle', label: 'Idle', badge: 'idle' },







    { value: 'Under Maintenance', label: 'Under Maintenance', badge: 'maintenance' },







    { value: 'Retired', label: 'Retired', badge: 'retired' }







  ];















  const conditionOptions = [







    { value: 'New', label: 'New', badge: 'new' },







    { value: 'Good', label: 'Good', badge: 'good' },







    { value: 'Fair', label: 'Fair', badge: 'fair' },







    { value: 'Needs Repair', label: 'Needs Repair', badge: 'repair' },







    { value: 'Disposed', label: 'Disposed', badge: 'disposed' }







  ];















  const emptyForm = {







    category: '',







    subCategory: '',







    assetType: '',







    brand: '',







    model: '',







    asset_tag: '',







    serial: '',







    assigned_location: '',







    department_assigned: '',







    status: 'Active',







    condition: 'Good',







    purchase_date: '',







    acquisition_cost: '',







    remarks: '',







    asset_plate_no: '',







    asset_unit_id: '',







    fuel_type: '',







    capacity: '',







    engine_no: '',







    chassis_no: '',







    year_manufactured: '',







    asset_specs: '',







    notes: ''







  };















  const [formData, setFormData] = useState(emptyForm);















  const mapAssetToForm = (existingAsset) => {







    const categoryPath = existingAsset?.category_id ? getCategoryPath(categories, existingAsset.category_id) : '';







    const [category = '', subCategory = ''] = categoryPath.split(' > ');















    return {







      category,







      subCategory,







      assetType: existingAsset?.equipment_type || existingAsset?.asset_type || '',







      brand: existingAsset?.brand || '',







      model: existingAsset?.model || '',







      asset_tag: existingAsset?.asset_tag || '',







      serial: existingAsset?.serial || '',







      assigned_location: existingAsset?.assigned_location || '',







      department_assigned: existingAsset?.department_assigned || '',







      status: existingAsset?.status || 'Active',







      condition: existingAsset?.condition || 'Good',







      purchase_date: existingAsset?.purchase_date ? existingAsset.purchase_date.split('T')[0] : '',







      acquisition_cost: existingAsset?.acquisition_cost != null ? existingAsset.acquisition_cost.toString() : '',







      remarks: existingAsset?.remarks || '',







      asset_plate_no: existingAsset?.asset_plate_no || '',







      asset_unit_id: existingAsset?.asset_unit_id || '',







      fuel_type: existingAsset?.fuel_type || '',







      capacity: existingAsset?.capacity != null ? existingAsset.capacity.toString() : '',







      engine_no: existingAsset?.engine_no || '',







      chassis_no: existingAsset?.chassis_no || '',







      year_manufactured: existingAsset?.year_manufactured ? existingAsset.year_manufactured.toString() : '',







      asset_specs: existingAsset?.asset_specs || '',







      notes: existingAsset?.notes || ''







    };







  };















  const resetForm = () => {







    setFormData(emptyForm);







    setPhotos({ userPhoto: null, assetPhoto: null });







    setErrors({});







    setSubCategories([]);







    setAssetTypes([]);







    setDynamicFields([]);







    setShowCategoryIntro(!isEditMode);







    initialFormRef.current = null;







  };















  useEffect(() => {







    if (isOpen) {







      loadMetadata();







      resetForm();







    }







  }, [isOpen]);















  useEffect(() => {







    if (!isOpen || !asset || categories.length === 0 || locations.length === 0) return;















    const mapped = mapAssetToForm(asset);







    initialFormRef.current = mapped;







    setFormData(mapped);







    setSubCategories(getSubCategories(categories, mapped.category));







    setAssetTypes(getAssetTypes(categories, mapped.category, mapped.subCategory));







  }, [isOpen, asset, categories, locations]);















  useEffect(() => {







    if (!formData.category) return;















    const subCats = getSubCategories(categories, formData.category);







    setSubCategories(subCats);







    setFormData(prev => {







      if (initialFormRef.current?.category === prev.category) {







        return prev;







      }







      return { ...prev, subCategory: '', assetType: '' };







    });







    setAssetTypes([]);







    setDynamicFields([]);







  }, [formData.category, categories]);















  useEffect(() => {







    if (!formData.category || !formData.subCategory) return;















    const types = getAssetTypes(categories, formData.category, formData.subCategory);







    setAssetTypes(types);







    setFormData(prev => {







      if (initialFormRef.current?.category === prev.category && initialFormRef.current?.subCategory === prev.subCategory) {







        return prev;







      }







      return { ...prev, assetType: '' };







    });







    setDynamicFields([]);







  }, [formData.subCategory, formData.category, categories]);















  useEffect(() => {







    if (formData.category && formData.subCategory && formData.assetType) {







      const fields = getDynamicFields(formData.category, formData.subCategory, formData.assetType);







      const enrichedFields = fields.map(field => {







        if (field.name === 'assigned_location') {







          return {







            ...field,







            options: locations.map(loc => ({







              value: loc.id,







              label: `${loc.location_code} — ${loc.location_name}`







            }))







          };







        }







        return field;







      });







      setDynamicFields(enrichedFields);







    }







  }, [formData.assetType, formData.category, formData.subCategory, locations]);















  const loadMetadata = async () => {







    try {







      const [categoryData, locationData] = await Promise.all([







        fetchAssetCategories(),







        fetchLocations()







      ]);







      setCategories(categoryData);







      setLocations(locationData);







    } catch (err) {







      console.error('Failed to load asset metadata:', err);







    }







  };















  const handleChange = (event) => {







    const { name, value } = event.target;







    setFormData(prev => ({ ...prev, [name]: value }));







    setErrors(prev => ({ ...prev, [name]: null }));







  };







  const handleCategoryIntroNext = () => {







    if (!formData.category) return;







    setErrors(prev => ({ ...prev, category: null }));







    setShowCategoryIntro(false);







  };















  const handlePhotoCapture = (photoData) => {







    if (showPhotoCapture === 'user') {







      setPhotos(prev => ({ ...prev, userPhoto: photoData }));







    } else if (showPhotoCapture === 'asset') {







      setPhotos(prev => ({ ...prev, assetPhoto: photoData }));







    }







    setShowPhotoCapture(null);







  };















  const validateForm = async () => {







    const validationErrors = {};















    if (!formData.category) validationErrors.category = 'Category is required';







    if (!formData.subCategory) validationErrors.subCategory = 'Sub-category is required';







    if (!formData.assetType) validationErrors.assetType = 'Asset type is required';







    if (!formData.brand) validationErrors.brand = 'Brand is required';







    if (!formData.model) validationErrors.model = 'Model is required';







    if (!formData.asset_tag) validationErrors.asset_tag = 'Asset tag is required';







    if (!formData.assigned_location) validationErrors.assigned_location = 'Location is required';







    if (!formData.department_assigned) validationErrors.department_assigned = 'Department is required';







    if (!photos.userPhoto) validationErrors.userPhoto = 'User photo is required for audit tracking';















    if (!formData.asset_tag) {







      validationErrors.asset_tag = 'Asset tag is required';







    } else {







      const assetTagCheck = await validateAssetTag(formData.asset_tag, asset?.id);







      if (!assetTagCheck.isValid) validationErrors.asset_tag = assetTagCheck.error;







    }















    const locationCheck = await validateLocationSelection(formData.assigned_location);







    if (!locationCheck.isValid) validationErrors.assigned_location = locationCheck.error;















    const assetValidation = await validateAssetByType(formData, formData.assetType, asset?.id);







    if (!assetValidation.isValid) {







      Object.assign(validationErrors, assetValidation.errors);







    }















    setErrors(validationErrors);







    return Object.keys(validationErrors).length === 0;







  };















  const buildEquipmentPayload = () => {







    const payload = {







      category_id: getCategoryId(categories, formData.category, formData.subCategory, formData.assetType),







      equipment_type: formData.assetType,







      brand: formData.brand,







      model: formData.model,







      asset_tag: formData.asset_tag,







      serial: formData.serial || null,







      assigned_location: formData.assigned_location,







      department_assigned: formData.department_assigned,







      status: formData.status,







      condition: formData.condition,







      purchase_date: formData.purchase_date || null,







      acquisition_cost: formData.acquisition_cost ? parseFloat(formData.acquisition_cost) : null,







      remarks: formData.remarks,







      asset_plate_no: formData.asset_plate_no || null,







      asset_unit_id: formData.asset_unit_id || null,







      fuel_type: formData.fuel_type || null,







      capacity: formData.capacity ? parseFloat(formData.capacity) : null,







      engine_no: formData.engine_no || null,







      chassis_no: formData.chassis_no || null,







      year_manufactured: formData.year_manufactured ? Number(formData.year_manufactured) : null,







      asset_specs: formData.asset_specs || null,







      created_by_id: isEditMode ? asset?.created_by_id || currentUser?.id || null : currentUser?.id || null,







      ...(isEditMode ? { updated_at: new Date().toISOString() } : { created_at: new Date().toISOString() })







    };















    return payload;







  };















  const handleSubmit = async (event) => {







    event.preventDefault();







    setLoading(true);















    try {







      const isValid = await validateForm();







      if (!isValid) {







        setLoading(false);







        return;







      }















      const equipmentPayload = buildEquipmentPayload();







      let savedAsset = null;







      let auditAction = 'CREATE';







      let oldValues = null;















      if (isEditMode) {







        auditAction = 'UPDATE';







        oldValues = asset;







        const { data: updatedData, error: updateError } = await supabase







          .from('equipment')







          .update([equipmentPayload])







          .eq('id', asset.id)







          .select();















        if (updateError) throw updateError;







        savedAsset = updatedData?.[0];







      } else {







        const { data: insertedData, error: insertError } = await supabase







          .from('equipment')







          .insert([equipmentPayload])







          .select();















        if (insertError) throw insertError;







        savedAsset = insertedData?.[0];







      }















      const gps = await getFullLocation();







      await logAudit({







        equipmentId: savedAsset.id,







        action: auditAction,







        oldValues,







        newValues: savedAsset,







        user: {







          id: currentUser?.id,







          name: currentUser?.name,







          employeeId: currentUser?.employeeId,







          department: currentUser?.department







        },







        photos,







        gps,







        notes: formData.notes || (isEditMode ? 'Asset updated through logistics form' : 'Asset added through logistics form')







      });















      if (onSaved) {







        onSaved(savedAsset, isEditMode);







      } else {







        alert(isEditMode ? 'Asset updated successfully.' : 'Asset added successfully.');







      }















      resetForm();







      onClose();







    } catch (err) {







      console.error('Failed to save asset:', err);







      alert(err?.message || 'Unable to save asset at this time.');







    } finally {







      setLoading(false);







    }







  };















  const renderField = (field) => {







    const value = formData[field.name] || '';







    const fieldError = errors[field.name];















    const commonProps = {







      name: field.name,







      value,







      onChange: handleChange,







      className: 'form-input',







      placeholder: field.placeholder || ''







    };















    if (field.type === 'textarea') {







      return (







        <textarea







          {...commonProps}







          rows={3}







          className="form-input form-textarea"







        />







      );







    }















    if (field.type === 'select') {







      return (







        <select {...commonProps}>







          <option value="">Select {field.label}</option>







          {(field.options || []).map(option => (







            <option key={option.value || option} value={option.value ?? option}>







              {option.label ?? option}







            </option>







          ))}







        </select>







      );







    }















    return (







      <input







        {...commonProps}







        type={field.type}







        min={field.type === 'number' ? '0' : undefined}







      />







    );







  };















  if (!isOpen) return null;















  return (







    <>







      {showPhotoCapture && (







        <PhotoCapture







          photoType={showPhotoCapture}







          onPhotoCapture={handlePhotoCapture}







          onClose={() => setShowPhotoCapture(null)}







        />







      )}















      <div className="modal-overlay">







        <div className="modal modal-scrollable">







          <div className="modal-header">







            <div>







              <h2 className="modal-title">{showCategoryIntro ? 'ADD NEW ASSET' : (isEditMode ? 'Edit Logistics Asset' : 'Add Logistics Asset')}</h2>







              <p className="modal-description text-sm">







                {showCategoryIntro ? 'Select the main asset category to begin.' : (isEditMode ? 'Update transport, warehouse, IT, or support equipment details' : 'Add new transport, warehouse, IT, or support equipment')}







              </p>







            </div>







            <button className="modal-close" onClick={onClose}>







              <X size={20} />







            </button>







          </div>















          {showCategoryIntro ? (







            <div className="asset-category-intro">







              <div className="asset-category-rule" />







              <div className="asset-category-instruction">







                <strong>INSTRUCTION:</strong> Please select the main category first.







              </div>







              <div className="asset-category-field">







                <label className="form-label" htmlFor="introAssetCategory">Asset Category:</label>







                <select







                  id="introAssetCategory"







                  name="category"







                  className="form-input asset-category-select"







                  value={formData.category}







                  onChange={handleChange}







                >







                  <option value="">Select One</option>







                  {getMainCategories(categories).map(category => (







                    <option key={category} value={category}>{category}</option>







                  ))}







                </select>







              </div>







              {errors.category && <p className="error-text asset-category-error">{errors.category}</p>}







              <div className="asset-category-actions">







                <button







                  type="button"







                  className="btn btn-primary"







                  onClick={handleCategoryIntroNext}







                  disabled={!formData.category}







                >







                  Next







                </button>







                <button type="button" className="btn btn-secondary" onClick={onClose}>







                  Cancel







                </button>







              </div>







              <div className="asset-category-rule" />







              <p className="asset-category-note">Note: The NEXT button will only work after a category is chosen</p>







            </div>







          ) : (







          <form onSubmit={handleSubmit}>







            <div className="modal-body space-y-6">







              <div className="modal-summary-grid">







                <div className="modal-summary-card">







                  <div className="summary-title">Asset Overview</div>







                  <div className="summary-item">







                    <span className="summary-label">Category</span>







                    <span className="summary-value">{formData.category || 'Not selected'}</span>







                  </div>







                  <div className="summary-item">







                    <span className="summary-label">Type</span>







                    <span className="summary-value">{formData.assetType || 'Not selected'}</span>







                  </div>







                  <div className="summary-item">







                    <span className="summary-label">Location</span>







                    <span className="summary-value">{locations.find(loc => loc.id === formData.assigned_location)?.location_code || 'Not assigned'}</span>







                  </div>







                  <div className="summary-item">







                    <span className="summary-label">Department</span>







                    <span className="summary-value">{formData.department_assigned || 'Not entered'}</span>







                  </div>







                </div>







                <div className="modal-summary-card">







                  <div className="summary-title">Current status</div>







                  <div className="status-chip-group summary-status-grid">







                    {statusOptions.map(option => (







                      <button







                        key={option.value}







                        type="button"







                        className={`status-chip ${formData.status === option.value ? 'selected' : ''} ${option.badge}`}







                        onClick={() => setFormData(prev => ({ ...prev, status: option.value }))}







                      >







                        {option.label}







                      </button>







                    ))}







                  </div>







                  <div className="status-chip-group condition-group summary-status-grid">







                    {conditionOptions.map(option => (







                      <button







                        key={option.value}







                        type="button"







                        className={`status-chip ${formData.condition === option.value ? 'selected' : ''} ${option.badge}`}







                        onClick={() => setFormData(prev => ({ ...prev, condition: option.value }))}







                      >







                        {option.label}







                      </button>







                    ))}







                  </div>







                  <div className="summary-item">







                    <span className="summary-label">Photos</span>







                    <span className="summary-value">







                      {photos.userPhoto && photos.assetPhoto ? 'Complete' : 'Missing'}







                    </span>







                  </div>







                </div>







              </div>







              <section className="modal-section">







                <div className="section-header">







                  <h4 className="section-heading">Asset Categorization</h4>







                  <span className="section-pill">Step 1</span>







                </div>







                <p className="section-subtitle">Define the asset classification and unlock type-specific fields for the next section.</p>







                <div className="modal-panel">







                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Category *</label>







                      <select







                        name="category"







                        className="form-input"







                        value={formData.category}







                        onChange={handleChange}







                        required







                      >







                        <option value="">Select Category</option>







                        {getMainCategories(categories).map(category => (







                          <option key={category} value={category}>{category}</option>







                        ))}







                      </select>







                      {errors.category && <p className="error-text">{errors.category}</p>}







                    </div>















                    <div className="form-group">







                      <label className="form-label">Sub-Category *</label>







                      <select







                        name="subCategory"







                        className="form-input"







                        value={formData.subCategory}







                        onChange={handleChange}







                        disabled={!formData.category}







                        required







                      >







                        <option value="">Select Sub-Category</option>







                        {subCategories.map(sub => (







                          <option key={sub} value={sub}>{sub}</option>







                        ))}







                      </select>







                      {errors.subCategory && <p className="error-text">{errors.subCategory}</p>}







                    </div>







                  </div>















                  <div className="form-row">







                    <div className="form-group full-width">







                      <label className="form-label">Asset Type *</label>







                      <select







                        name="assetType"







                        className="form-input"







                        value={formData.assetType}







                        onChange={handleChange}







                        disabled={!formData.subCategory}







                        required







                      >







                        <option value="">Select Asset Type</option>







                        {assetTypes.map(type => (







                          <option key={type} value={type}>{type}</option>







                        ))}







                      </select>







                      {errors.assetType && <p className="error-text">{errors.assetType}</p>}







                    </div>







                  </div>







                </div>







              </section>















              <section className="modal-section">







                <div className="section-header">







                  <h4 className="section-heading">Asset Details</h4>







                  <span className="section-pill">Step 2</span>







                </div>







                <p className="section-subtitle">Capture the key identifiers and tracking details for the asset.</p>







                <div className="modal-panel">







                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Brand *</label>







                      <input







                        type="text"







                        name="brand"







                        className="form-input"







                        value={formData.brand}







                        onChange={handleChange}







                        placeholder="Enter brand"







                        required







                      />







                      {errors.brand && <p className="error-text">{errors.brand}</p>}







                    </div>















                    <div className="form-group">







                      <label className="form-label">Model *</label>







                      <input







                        type="text"







                        name="model"







                        className="form-input"







                        value={formData.model}







                        onChange={handleChange}







                        placeholder="Enter model"







                        required







                      />







                      {errors.model && <p className="error-text">{errors.model}</p>}







                    </div>







                  </div>















                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Asset Tag *</label>







                      <input







                        type="text"







                        name="asset_tag"







                        className="form-input"







                        value={formData.asset_tag}







                        onChange={handleChange}







                        placeholder="AST-0001"







                        required







                      />







                      {errors.asset_tag && <p className="error-text">{errors.asset_tag}</p>}







                    </div>















                    <div className="form-group">







                      <label className="form-label">Serial / IMEI</label>







                      <input







                        type="text"







                        name="serial"







                        className="form-input"







                        value={formData.serial}







                        onChange={handleChange}







                        placeholder="Optional, if available"







                      />







                      {errors.serial && <p className="error-text">{errors.serial}</p>}







                    </div>







                  </div>







                </div>







              </section>















              {dynamicFields.length > 0 && (







                <section className="modal-section">







                  <div className="section-header">







                    <h4 className="section-heading">Type-Specific Fields</h4>







                    <span className="section-pill">Step 3</span>







                  </div>







                  <p className="section-subtitle">Complete any additional fields that are required for this specific asset type.</p>







                  <div className="modal-panel">







                    <div className="form-row flex-wrap">







                      {dynamicFields.map(field => (







                        <div key={field.name} className="form-group responsive-field">







                          <label className="form-label">







                            {field.label}{field.required ? ' *' : ''}







                          </label>







                          {renderField(field)}







                          {errors[field.name] && <p className="error-text">{errors[field.name]}</p>}







                        </div>







                      ))}







                    </div>







                  </div>







                </section>







              )}















              <section className="modal-section">







                <div className="section-header">







                  <h4 className="section-heading">Photo Documentation</h4>







                  <span className="section-pill">Step 4</span>







                </div>







                <p className="section-subtitle">Capture required photos to support audit tracking and asset verification.</p>







                <div className="modal-panel">







                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">User Verification *</label>







                      <button







                        type="button"







                        onClick={() => setShowPhotoCapture('user')}







                        className={`photo-button ${photos.userPhoto ? 'captured' : ''}`}







                      >







                        <Camera size={16} />







                        {photos.userPhoto ? 'User Photo Captured' : 'Capture User Photo'}







                      </button>







                      {errors.userPhoto && <p className="error-text">{errors.userPhoto}</p>}







                    </div>















                    <div className="form-group">







                      <label className="form-label">Asset Photo</label>







                      <button







                        type="button"







                        onClick={() => setShowPhotoCapture('asset')}







                        className={`photo-button ${photos.assetPhoto ? 'captured' : ''}`}







                      >







                        <Camera size={16} />







                        {photos.assetPhoto ? 'Asset Photo Captured' : 'Capture Asset Photo'}







                      </button>







                    </div>







                  </div>







                </div>







              </section>















              <section className="modal-section">







                <div className="section-header">







                  <h4 className="section-heading">Location & Assignment</h4>







                  <span className="section-pill">Step 5</span>







                </div>







                <p className="section-subtitle">Assign this asset to its location and team so it can be tracked in operations.</p>







                <div className="modal-panel">







                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Assigned Location *</label>







                      <select







                        name="assigned_location"







                        className="form-input"







                        value={formData.assigned_location}







                        onChange={handleChange}







                        required







                      >







                        <option value="">Select Location</option>







                        {locations.map(loc => (







                          <option key={loc.id} value={loc.id}>{loc.location_code} — {loc.location_name}</option>







                        ))}







                      </select>







                      {errors.assigned_location && <p className="error-text">{errors.assigned_location}</p>}







                    </div>















                    <div className="form-group">







                      <label className="form-label">Department *</label>







                      <input







                        type="text"







                        name="department_assigned"







                        className="form-input"







                        value={formData.department_assigned}







                        onChange={handleChange}







                        placeholder="Enter department"







                        required







                      />







                      {errors.department_assigned && <p className="error-text">{errors.department_assigned}</p>}







                    </div>







                  </div>







                </div>







              </section>















              <section className="modal-section">







                <div className="section-header">







                  <h4 className="section-heading">Additional Details</h4>







                  <span className="section-pill">Step 6</span>







                </div>







                <p className="section-subtitle">Set status, condition, financial details, and notes for operations and audits.</p>







                <div className="status-chip-group">







                  {statusOptions.map(option => (







                    <button







                      key={option.value}







                      type="button"







                      className={`status-chip ${formData.status === option.value ? 'selected' : ''} ${option.badge}`}







                      onClick={() => setFormData(prev => ({ ...prev, status: option.value }))}







                    >







                      {option.label}







                    </button>







                  ))}







                </div>







                <div className="status-chip-group condition-group">







                  {conditionOptions.map(option => (







                    <button







                      key={option.value}







                      type="button"







                      className={`status-chip ${formData.condition === option.value ? 'selected' : ''} ${option.badge}`}







                      onClick={() => setFormData(prev => ({ ...prev, condition: option.value }))}







                    >







                      {option.label}







                    </button>







                  ))}







                </div>







                <div className="modal-panel">







                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Status *</label>







                      <select







                        name="status"







                        className="form-input"







                        value={formData.status}







                        onChange={handleChange}







                      >







                        <option value="Active">Active</option>







                        <option value="In Use">In Use</option>







                        <option value="Idle">Idle</option>







                        <option value="Under Maintenance">Under Maintenance</option>







                        <option value="Retired">Retired</option>







                      </select>







                    </div>















                    <div className="form-group">







                      <label className="form-label">Condition *</label>







                      <select







                        name="condition"







                        className="form-input"







                        value={formData.condition}







                        onChange={handleChange}







                      >







                        <option value="New">New</option>







                        <option value="Good">Good</option>







                        <option value="Fair">Fair</option>







                        <option value="Needs Repair">Needs Repair</option>







                        <option value="Disposed">Disposed</option>







                      </select>







                    </div>







                  </div>















                  <div className="form-row">







                    <div className="form-group">







                      <label className="form-label">Acquisition Date *</label>







                      <input







                        type="date"







                        name="purchase_date"







                        className="form-input"







                        value={formData.purchase_date}







                        onChange={handleChange}







                      />







                    </div>















                    <div className="form-group">







                      <label className="form-label">Acquisition Cost *</label>







                      <input







                        type="number"







                        name="acquisition_cost"







                        className="form-input"







                        value={formData.acquisition_cost}







                        onChange={handleChange}







                        placeholder="0.00"







                        step="0.01"







                      />







                    </div>







                  </div>















                  <div className="form-group">







                    <label className="form-label">Remarks</label>







                    <textarea







                      name="remarks"







                      className="form-input form-textarea"







                      rows={3}







                      value={formData.remarks}







                      onChange={handleChange}







                      placeholder="Optional notes or special handling instructions"







                    />







                  </div>















                  <div className="form-group">







                    <label className="form-label">Audit Notes</label>







                    <textarea







                      name="notes"







                      className="form-input form-textarea"







                      rows={3}







                      value={formData.notes}







                      onChange={handleChange}







                      placeholder="Additional audit notes"







                    />







                  </div>







                </div>







              </section>







            </div>















            <div className="modal-footer">







              <button type="button" className="btn btn-secondary" onClick={onClose} disabled={loading}>







                Cancel







              </button>







              <button type="submit" className="btn btn-primary" disabled={loading}>







                {loading ? (isEditMode ? 'Saving changes...' : 'Saving asset...') : (isEditMode ? 'Update Asset' : 'Save Asset')}







              </button>







            </div>







          </form>







          )}







        </div>







      </div>







    </>







  );







};















export default AddAssetModal;







